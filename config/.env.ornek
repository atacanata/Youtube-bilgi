# === YouTube Arama (ZORUNLU) ===
# Google Cloud Console > APIs & Services > Credentials > API key
YOUTUBE_API_KEY=buraya_youtube_api_anahtarini_yapistir

# === Sentez Modeli Seçimi ===
# "lokal" = vLLM (GPU geldiğinde) | "claude" = Anthropic API
MODEL_SAGLAYICI=lokal

# --- Lokal vLLM ayarları (MODEL_SAGLAYICI=lokal ise) ---
VLLM_URL=http://localhost:8000
VLLM_MODEL=google/gemma-4-31B-it

# --- Claude API ayarları (MODEL_SAGLAYICI=claude ise) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
